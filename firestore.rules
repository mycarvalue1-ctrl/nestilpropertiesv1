rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Direct UID check for the administrator account.
      return request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    function isOwner(ownerId) {
      // Checks if the requesting user is the owner of the resource.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      // Only the user themselves can manage their own favorites.
      allow read, write: if isOwner(userId);
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // LIST: A query on the properties collection is allowed if, FOR EVERY DOCUMENT IN THE RESULT:
      // 1. The user is an admin.
      // 2. OR the property is approved for public viewing.
      // 3. OR the user is the owner of the property.
      // This forces unauthenticated queries to include `where('isApproved', '==', true)`.
      allow list: if isAdmin() || (resource.data.isApproved == true) || isOwner(resource.data.ownerId);

      // GET: Allows reading a single document if it's approved or the user has rights.
      // Simplified to allow all reads, as client queries are already filtered for isApproved == true.
      allow get: if true;

      // CREATE: Any signed-in user can create a property for themselves.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // UPDATE / DELETE: Only the owner or an admin can modify/delete.
      allow update, delete: if isAdmin() || isOwner(resource.data.ownerId);
    }

    // =================================
    // Site Visit Rules
    // =================================
    match /site_visits/{visitId} {
      // Visitor can create their own request.
      allow create: if isOwner(request.resource.data.visitorId);

      // A read is allowed by the visitor, the owner, or an admin.
      // A query must be constrained to what the user can see (by visitorId or ownerId),
      // unless the user is an admin.
      allow read: if isOwner(resource.data.visitorId) || isOwner(resource.data.ownerId) || isAdmin();
      
      // Owner can update the status of the request (confirm/reject). Admin can too.
      allow update: if isOwner(resource.data.ownerId) || isAdmin();
      
      // For record-keeping, prevent deletion for now.
      allow delete: if false;
    }


    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
