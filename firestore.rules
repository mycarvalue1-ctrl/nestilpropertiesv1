
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // This logic must match the front-end check in /admin/layout.tsx
      return request.auth != null && request.auth.token.email == 'helpnestil@gmail.com';
    }

    // Rules for the 'properties' collection
    match /properties/{propertyId} {
      // --- READS ---
      // GET: Allow reading a single document if it's approved, OR if the user is the owner OR an admin.
      allow get: if resource.data.listingStatus == 'approved'
                  || (resource.data.ownerId != null && isOwner(resource.data.ownerId))
                  || isAdmin();

      // LIST: Allow anyone to query. Security is enforced by Firestore ensuring
      // the query *only* returns documents the user has 'get' access to.
      // This works because our public queries filter for 'listingStatus == "approved"'.
      allow list: if true;

      // --- WRITES ---
      // CREATE: An authenticated user can create a property for themselves.
      // Rule enforces that the ownerId matches the user's UID and it starts as 'pending'.
      allow create: if isOwner(request.resource.data.ownerId)
                    && request.resource.data.listingStatus == 'pending';

      // UPDATE: An owner can update their own properties, but cannot approve it themselves.
      // The app logic resets a property to 'pending' on any owner edit for re-review.
      // An admin can update any field.
      allow update: if (isOwner(resource.data.ownerId) && request.resource.data.listingStatus != 'approved')
                    || isAdmin();

      // DELETE: Only admins can delete properties.
      allow delete: if isAdmin();
    }

    // Rules for the 'propertyPrivateDetails' collection
    match /propertyPrivateDetails/{propertyId} {
      // Allow any authenticated user to read contact details.
      // This is necessary so users can contact property owners.
      allow read: if request.auth != null;
      
      // Allow writing if the user is the owner (based on incoming data) or an admin.
      allow write: if isOwner(request.resource.data.ownerId) || isAdmin();

      // DELETE: Only admins can delete the private details document.
      allow delete: if isAdmin();
    }

    // Rules for user-specific data, like favorites in `/users/{userId}/favorites/{propertyId}`
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
