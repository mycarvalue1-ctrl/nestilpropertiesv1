rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // The admin is identified by their email address.
      return isSignedIn() && request.auth.token.email == 'helpnestil@gmail.com';
    }

    function isOwner(ownerId) {
      // The user is the owner of a document if they are signed in AND their UID matches the ownerId field.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules (Public Data)
    // =================================
    match /properties/{propertyId} {
      // --- WRITES ---
      // Only signed-in users can create a property, and they must be the owner.
      allow create: if isOwner(request.resource.data.ownerId);

      // Only the property owner or an admin can update or delete.
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();

      // --- READS ---
      // The `get` rule is the gatekeeper for all reads.
      // It ensures that for any query, only approved properties are returned to the client,
      // unless the user is the owner or an admin.
      allow get: if resource.data.listingStatus == 'approved' 
                  || (isSignedIn() && resource.data.ownerId == request.auth.uid)
                  || isAdmin();

      // The `list` rule allows anyone to construct a query.
      // However, the `get` rule above is checked on every single document
      // before it's returned, effectively filtering the results on the backend.
      // This means any public query MUST use `where('listingStatus', '==', 'approved')`
      // on the client-side to get any results.
      allow list: if true;
    }
    
    // =================================
    // Property Private Details Rules
    // =================================
    match /propertyPrivateDetails/{propertyId} {
        // Only a logged-in user can read the contact details.
        // The app logic (credits/subscription) should be handled on the client.
        allow read: if isSignedIn();

        // Only the actual property owner or an admin can create/edit/delete private details.
        // We use get() to look up the ownerId from the main properties collection.
        allow write: if (isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId) || isAdmin());
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // An admin, property owner, or visitor can read a visit request.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      // An admin or property owner can update the status (confirm/reject).
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      // A visitor can create a request for themselves.
      allow create: if isOwner(request.resource.data.visitorId);
      // Deletion is disabled for record-keeping.
      allow delete: if false;
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      // Anyone can read the list of amenities.
      allow get, list: if true;
      // Only admins can write to the list of amenities.
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      // Anyone can read the list of nearby place types.
      allow get, list: if true;
      // Only admins can write to this list.
      allow write: if isAdmin();
    }
  }
}
