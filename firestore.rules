rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Safely check for admin UID, ensuring user is signed in first.
      return isSignedIn() && request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    function isOwner(ownerId) {
      // Checks if the requesting user is the owner of the resource.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      // User can manage their own favorites, admin has full access to all favorites.
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // Admin Rules: Grant blanket read/write access to admins.
      // This is checked first. Because it has no dependency on `resource.data`,
      // it allows unfiltered list queries for admins.
      allow read, write: if isAdmin();

      // User Rules: Apply only if the user is NOT an admin.
      // GET: Allow reading a single document if it's approved OR if the user is the owner.
      allow get: if !isAdmin() && (isOwner(resource.data.ownerId) || resource.data.isApproved == true);
      
      // LIST: Allow querying documents ONLY if they are approved.
      // This forces all non-admin list queries to use `where('isApproved', '==', true)`.
      allow list: if !isAdmin() && resource.data.isApproved == true;

      // WRITE for Users: Owners can create/update their own properties.
      allow create: if !isAdmin() && isOwner(request.resource.data.ownerId);
      allow update: if !isAdmin() && isOwner(resource.data.ownerId);
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // Allow read/update if admin, owner, or visitor.
      allow read, update: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      
      // Separate list rule for queries
      allow list: if isAdmin() || (isSignedIn() && request.query.get('ownerId') == request.auth.uid);

      // Permissions for non-admins.
      allow create: if isOwner(request.resource.data.visitorId);
      allow delete: if false; // Deletion is disabled for record-keeping.
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      allow get, list: if true;
      allow write: if isAdmin(); // create, update, delete
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      allow get, list: if true;
      allow write: if isAdmin(); // create, update, delete
    }
  }
}
