/**
 * # Firestore Security Rules: PropertyLink
 *
 * ## Core Philosophy
 * This ruleset enforces a mixed security model tailored for a real estate application.
 * It combines strict user ownership for private data, role-based access for administrators,
 * and a public-read/owner-write model for shared data like property listings. The primary
 * goal is to ensure users can only access and manage their own information while allowing
 * admins to moderate the platform and visitors to browse approved content.
 *
 * ## Data Structure
 * - `/users/{userId}`: Stores private user profiles. Access is restricted to the owner.
 * - `/users/{userId}/favorite_properties/{favId}`: A user-owned subcollection for their favorites.
 * - `/properties/{propertyId}`: A public collection of property listings. Listings are
 *   publicly readable only if approved. Writes are restricted to the property owner or an admin.
 * - `/amenities/{amenityId}` & `/nearby_place_types/{typeId}`: Public, read-only collections
 *   for reference data, managed exclusively by administrators.
 *
 * ## Key Security Decisions
 * - **Admin Roles**: Administrator status is determined by a user's email address being
 *   `mycarvalue1@gmail.com`. For development, email verification is NOT required, but
 *   it should be re-enabled for production.
 * - **Public Listings**: The visibility of properties is controlled by an `isApproved` flag.
 *   This is the cornerstone of public access. Client queries for public listings MUST
 *   filter by `where('isApproved', '==', true)` for `list` operations to succeed.
 * - **User Privacy**: User profiles and their associated data are strictly private. Listing
 *   all users is disallowed for non-admins to prevent data scraping.
 *
 * ## Denormalization for Authorization
 * - **Property Ownership**: Each document in `/properties` contains a denormalized `ownerId`
 *   field. This allows security rules to verify ownership for write operations directly and
 *   efficiently, without needing a costly `get()` to another collection.
 *
 * ## Structural Segregation
 * - User-specific data (`favorite_properties`) is nested under the `/users/{userId}` path,
 *   naturally isolating it and simplifying ownership rules.
 * - Publicly readable but admin-managed data (`amenities`, `nearby_place_types`) is placed
 *   in separate top-level collections to enforce a simple, uniform security policy.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the user is the designated administrator.
     * IMPORTANT: For production, re-enable `request.auth.token.email_verified == true`.
     */
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == 'mycarvalue1@gmail.com';
    }

    // ------------------------------------------------------------------------
    // User Data Rules
    // ------------------------------------------------------------------------

    /**
     * @description A user can create, read, and manage their own profile document. Admins have full access.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description A user can manage their own list of favorite properties.
     * @path /users/{userId}/favorite_properties/{favoritePropertyId}
     */
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      allow read, write: if isOwner(userId);
    }

    // ------------------------------------------------------------------------
    // Application Content Rules
    // ------------------------------------------------------------------------

    /**
     * @description Property listings have multiple access levels for reading and writing.
     * - Admins can read/write anything.
     * - Owners can read/update/delete their own properties.
     * - Any signed-in user can create a property.
     * - Anyone (even unauthenticated) can read properties where `isApproved` is true.
     * @path /properties/{propertyId}
     */
    match /properties/{propertyId} {
      // READ rule: Combines all valid read scenarios.
      // An admin can read anything.
      // An owner can read their own document.
      // Anyone can read a document if it is approved.
      allow read: if isAdmin() || 
                     (isSignedIn() && isOwner(resource.data.ownerId)) || 
                     resource.data.isApproved == true;

      // CREATE rule: Any authenticated user can create a property for themselves.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      // UPDATE/DELETE rules: Only the owner or an admin can modify/delete.
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(resource.data.ownerId));
    }


    /**
     * @description The list of available amenities is public and read-only for non-admins.
     * @path /amenities/{amenityId}
     */
    match /amenities/{amenityId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description The list of nearby place types is public and read-only for non-admins.
     * @path /nearby_place_types/{nearbyPlaceTypeId}
     */
    match /nearby_place_types/{nearbyPlaceTypeId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
