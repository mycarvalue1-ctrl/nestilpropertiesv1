rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // TEMPORARY DEBUGGING RULE
    // This is intentionally insecure to diagnose a permissions issue.
    // It allows anyone to read or write any document in the database.
    // =====================================================================
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
