rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Direct UID check for the administrator account.
      return request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    function isOwner(ownerId) {
      // Checks if the requesting user is the owner of the resource.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      // Admin has full CRUD access. Users can read/update their own profile.
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      // User can manage their own favorites, admin has full access to all favorites.
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // READ (get, list):
      // Anyone can read a property if it's approved.
      // The owner or an admin can read it regardless of approval status.
      // This rule works because client-side queries MUST filter by `isApproved == true` for public users.
      allow read: if (resource.data.isApproved == true) || 
                   (isSignedIn() && isOwner(resource.data.ownerId)) || 
                   isAdmin();

      // CREATE: Any signed-in user can create a property for themselves.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // UPDATE / DELETE: Only the owner or an admin can modify/delete.
      allow update, delete: if (isSignedIn() && isOwner(resource.data.ownerId)) || isAdmin();
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      allow get, list: if true;
      allow write: if isAdmin(); // create, update, delete
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      allow get, list: if true;
      allow write: if isAdmin(); // create, update, delete
    }
  }
}
