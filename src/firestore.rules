rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // The user is an admin if they are signed in AND their UID matches the specific admin UID.
      return isSignedIn() && request.auth.uid == 'IultEIQMgAUPwoqAEWX7ZIunjNB3';
    }

    function isOwner(ownerId) {
      // The user is the owner of a document if they are signed in AND their UID matches the ownerId field.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      // An admin can read/update any profile. A user can only read/update their own.
      allow read, update: if isOwner(userId) || isAdmin();
      // A user can create their own user document.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Only an admin can delete a user document.
      allow delete: if isAdmin();
      // Only an admin can list all users.
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      // A user can manage their own favorites. An admin has full access.
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // --- WRITE Rules (Create, Update, Delete) ---
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isOwner(resource.data.ownerId) || isAdmin();
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();

      // --- READ Rules (Get) ---
      // GET (Single Document): Allow if admin, owner, or the property is approved.
      allow get: if isAdmin() || isOwner(resource.data.ownerId) || resource.data.isApproved == true;
      
      // --- LIST Rules (Query) ---
      // Rule for public queries. MUST NOT require authentication.
      allow list: if request.query.where.get("isApproved") == true;

      // Rule for authenticated user queries. MUST require authentication.
      allow list: if isSignedIn() && (
        isAdmin() || // Admins can list anything
        request.query.where.get("ownerId") == request.auth.uid // Owners can list their own
      );
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // An admin, property owner, or visitor can read a visit request.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      // An admin or property owner can update the status (confirm/reject).
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      // A visitor can create a request for themselves.
      allow create: if isOwner(request.resource.data.visitorId);
      // Deletion is disabled for record-keeping.
      allow delete: if false;
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      // Anyone can read the list of amenities.
      allow get, list: if true;
      // Only admins can write to the list of amenities.
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      // Anyone can read the list of nearby place types.
      allow get, list: if true;
      // Only admins can write to this list.
      allow write: if isAdmin();
    }
  }
}
