
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // The admin is identified by their email address.
      return isSignedIn() && request.auth.token.email == 'helpnestil@gmail.com';
    }

    function isOwner(ownerId) {
      // The user is the owner of a document if they are signed in AND their UID matches the ownerId field.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      // A user can read and update their own profile. Admins can too.
      allow read, update: if isOwner(userId) || isAdmin();
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // Only an admin can delete a user.
      allow delete: if isAdmin();
    }

    // =================================
    // User Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      // A user can manage their own list of favorites.
      allow read, write: if isOwner(userId);
    }

    // =================================
    // Properties Collection Rules (Simplified for Development)
    // =================================
    match /properties/{propertyId} {
      // Any signed-in user can read/list all properties.
      // This removes complexity around 'isApproved' for now to prevent list errors.
      allow read: if isSignedIn();

      // Only the owner of a property or an admin can create, update, or delete it.
      allow write: if isOwner(request.resource.data.ownerId) || isAdmin();
    }
    
    // =================================
    // Property Private Details Rules
    // =================================
    match /propertyPrivateDetails/{propertyId} {
      // Any signed-in user can attempt to read private details.
      // Client-side logic handles whether they have credits/subscription to do so.
      allow read: if isSignedIn();

      // Only the property owner (checked via the main properties collection) or an admin can write these details.
      allow write: if (isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId) || isAdmin());
    }

    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // An admin, property owner, or the visitor can read the request.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      // An admin or the property owner can update the status.
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      // A visitor can create a request for themselves.
      allow create: if isOwner(request.resource.data.visitorId);
      // Deleting is disallowed to keep a history.
      allow delete: if false;
    }

    // =================================
    // Static Data (Read-Only for most users)
    // =================================
    match /amenities/{amenityId} {
      // Amenity list is public.
      allow read: if true;
      // Only admins can change the global amenities list.
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      // Nearby place types are public.
      allow read: if true;
      // Only admins can change this global list.
      allow write: if isAdmin();
    }
  }
}
