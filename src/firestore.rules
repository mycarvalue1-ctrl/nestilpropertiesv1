
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // The admin is identified by their email address.
      return isSignedIn() && request.auth.token.email == 'helpnestil@gmail.com';
    }

    function isOwner(ownerId) {
      // The user is the owner of a document if they are signed in AND their UID matches the ownerId field.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      
      function isPubliclyVisible() {
        return resource.data.isApproved == true;
      }

      // Anyone can attempt to query properties. The query's validity is
      // then determined by the 'get' rule below. This forces client queries
      // from non-admins to be specific (e.g., filter for approved listings).
      allow list: if true;
      
      // A single document can be read if it's publicly approved, or if the
      // requester is the property's owner or an admin.
      allow get: if isPubliclyVisible() || isOwner(resource.data.ownerId) || isAdmin();

      // Users can create properties for themselves.
      // Rules enforce that new properties start as 'pending' and not 'approved'.
      allow create: if isOwner(request.resource.data.ownerId)
                    && request.resource.data.isApproved == false
                    && request.resource.data.listingStatus == 'pending';

      // An owner can update their own property, but cannot approve it themselves.
      // An admin can update any property, including changing its approval status.
      function ownerCanUpdate() {
        return isOwner(resource.data.ownerId)
               && request.resource.data.isApproved == resource.data.isApproved; // Prevents owner from self-approving
      }
      allow update: if ownerCanUpdate() || isAdmin();

      // Only the owner or an admin can delete a property.
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
    
    // =================================
    // Property Private Details Rules
    // =================================
    match /propertyPrivateDetails/{propertyId} {
        // Logged-in users can read private details. The client-side logic
        // is responsible for handling credit/subscription checks before attempting the read.
        allow read: if isSignedIn();

        // Only the actual property owner or an admin can write private details.
        // This rule uses get() to securely check the ownerId from the main properties collection.
        allow write: if (isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId) || isAdmin());
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // An admin, property owner, or the visitor who made the request can read it.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      // An admin or the property owner can update the visit status.
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      // A visitor can create a request for themselves.
      allow create: if isOwner(request.resource.data.visitorId);
      // Deletion is disabled to maintain a record of visit requests.
      allow delete: if false;
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      // Anyone can read the list of amenities.
      allow get, list: if true;
      // Only admins can modify the list of amenities.
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      // Anyone can read the list of nearby place types.
      allow get, list: if true;
      // Only admins can modify this list.
      allow write: if isAdmin();
    }
  }
}
