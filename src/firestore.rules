
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // The admin is identified by their email address.
      return isSignedIn() && request.auth.token.email == 'helpnestil@gmail.com';
    }

    function isOwner(ownerId) {
      // The user is the owner of a document if they are signed in AND their UID matches the ownerId field.
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // =================================
    // User Profile Rules
    // =================================
    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // =================================
    // Favorite Properties (Subcollection)
    // =================================
    match /users/{userId}/favorite_properties/{favoritePropertyId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // =================================
    // Properties Collection Rules
    // =================================
    match /properties/{propertyId} {
      // DEV/TESTING RULE: To simplify development and testing, allow any
      // authenticated user to read and write all property data. This is less secure
      // but useful for unblocking UI development.
      allow read, write: if isSignedIn();
    }
    
    // =================================
    // Property Private Details Rules
    // =================================
    match /propertyPrivateDetails/{propertyId} {
        // Logged-in users can read private details. The client-side logic
        // is responsible for handling credit/subscription checks before attempting the read.
        allow read: if isSignedIn();

        // Only the actual property owner or an admin can write private details.
        // This rule uses get() to securely check the ownerId from the main properties collection.
        allow write: if (isOwner(get(/databases/$(database)/documents/properties/$(propertyId)).data.ownerId) || isAdmin());
    }


    // =================================
    // Site Visit Rules
    // =================================
     match /site_visits/{visitId} {
      // An admin, property owner, or the visitor who made the request can read it.
      allow read: if isAdmin() || isOwner(resource.data.ownerId) || isOwner(resource.data.visitorId);
      // An admin or the property owner can update the visit status.
      allow update: if isAdmin() || isOwner(resource.data.ownerId);
      // A visitor can create a request for themselves.
      allow create: if isOwner(request.resource.data.visitorId);
      // Deletion is disabled to maintain a record of visit requests.
      allow delete: if false;
    }

    // =================================
    // Static Data Collections
    // =================================
    match /amenities/{amenityId} {
      // Anyone can read the list of amenities.
      allow get, list: if true;
      // Only admins can modify the list of amenities.
      allow write: if isAdmin();
    }

    match /nearby_place_types/{nearbyPlaceTypeId} {
      // Anyone can read the list of nearby place types.
      allow get, list: if true;
      // Only admins can modify this list.
      allow write: if isAdmin();
    }
  }
}
